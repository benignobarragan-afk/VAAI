<%- include('../partials/header'); %>

<style>
/* Esto quita la restricción de una sola línea en los headers de Webix */
.header_multiline {
    white-space: normal !important;
    line-height: 1.2em !important;
    font-size: 15px !important; 
    padding: 5px 0;
    overflow: visible !important;
}

</style>

<body>
    <script>
        var tip = 0
        var w1;
        var mygrid;


        // Agregamos un listener de teclas global
        webix.event(window, "keydown", function(e){
            // 112 es el código de la tecla F1
            if (e.keyCode == 112) {
                
                // VITAL: Detener la ayuda del navegador
                if (e.preventDefault) e.preventDefault();
                
                // Ejecutar la lógica de tu botón
                $$("btn_guardar").callEvent("onItemClick"); 
                
                // O llamar directamente a tu función
                // miFuncionDeGuardado();

                return false;
            }
        });
        
        //alert(tip);

        //function doOnLoad() {
        webix.ready(function(){

            webix.ui.datafilter.rowCount = webix.extend({
                refresh: function (master, node, value) {
                    node.firstChild.innerHTML = "Total: " + master.count();
                }
            }, webix.ui.datafilter.summColumn)


            var ui = webix.ui({
                space: "wide",
                rows: [
                    {
                        view: "toolbar", padding: 3, borderless: true, elements: [
                            {
                                view: "button",
                                type: "icon",
                                icon: "mdi mdi-sync",
                                align: "left",
                                label: "",
                                width: 40,
                                on: {
                                    onItemClick: genera
                                }
                            },
                            <%if(llRevisor){%>
                            {
                                view: "button",
                                type: "icon",
                                icon: "mdi mdi-plus",
                                label: "Crear FOCAM",
                                width: 130,
                                on: {
                                    onItemClick: function () { deta_grup() }
                                }
                            },
                            <%}%>
                            {
                                view: "button",
                                type: "icon",
                                icon: "mdi mdi-file-excel",
                                label: "Descargar",
                                width: 130,
                                on: {
                                    onItemClick: function () { 
                                        webix.toExcel("dtable", {
                                            //spans:true,
                                            //styles:true
                                        });
                                     }
                                }
                            },
                            <%if(llRevisor){%>
                            {
                                view: "button",
                                type: "icon",
                                icon: "mdi mdi-file-document",
                                label: "Formato a firmar",
                                width: 150,
                                on: {
                                    onItemClick: function () { 
                                        const lnID = $$("dtable").getSelectedId()
                                        if(lnID === undefined){
                                            webix.message({type: "debug", text: "Selecciona un registro para generar el documentos", expire: 2500})
                                        }
                                        else {
                                            window.open(`/api/progap/progap_form01?id=${lnID}`, '_blank');
                                        }
                                        
                                        }
                                     }

                            },
                            {},
                            {
                                view: "checkbox",
                                id: "chk_todos",
                                labelRight: "Ver todos los movimientos",
                                labelWidth: 0,
                                width: 250,
                                on: {
                                    onChange: function(newVal, oldVal) {
                                        // newVal es 1 si está marcado, 0 si no
                                        genera();
                                    }
                                }
                            },
                            {
                                view: "button",
                                type: "icon",
                                id: "btn_Aceptar",
                                label: "Aceptar (Ctrl+A)",
                                icon: "mdi mdi-check-circle",
                                hotkey: "ctrl-a", 
                                width: 180,
                                click: function() {
                                    // 1. Obtenemos la tabla por su ID
                                    var tabla = $$("dtable");
                                    
                                    // 2. Obtenemos el ID de la fila seleccionada
                                    var idSeleccionado = tabla.getSelectedId();

                                    if (idSeleccionado) {
                                        webix.ajax().post("/api/progap/progap_focamx3", { id: idSeleccionado.id, acepta: true })
                                            .then(function(res) {
                                                var data = res.json();
                                                console.log(data)

                                                // Verificamos si el backend regresó éxito (asumiendo que mandas {status: "success"})
                                                if (data && data.status == "success") {
                                                    
                                                    // 1. Mensaje de éxito
                                                    webix.message({ type: "success", text: "Documento validado correctamente" });

                                                    // 2. Eliminamos la fila físicamente de la tabla
                                                    tabla.remove(idSeleccionado);

                                                    // 3. Seleccionamos el siguiente registro
                                                    var primerId = tabla.getFirstId();
                                                    if (primerId) {
                                                        tabla.select(primerId);
                                                    } else {
                                                        // Si ya no hay registros, limpiamos el visor de PDF
                                                        $$("visor_progap").setValues({ src: "" });
                                                    }

                                                } else {
                                                    // Manejo de error lógico (ej. el registro ya estaba validado)
                                                    webix.alert({
                                                        title: "Atención",
                                                        type: "alert-error",
                                                        text: data.message || "Hubo un problema al validar el documento"
                                                    });
                                                }
                                            })
                                            .catch(function(err) {
                                                tabla.hideProgress();
                                                // Manejo de error de red o servidor (Error 500, 404, etc.)
                                                webix.message({ type: "error", text: "Error de conexión con el servidor" });
                                                console.error("Error Ajax:", err);
                                            });
                                        
                                    } else {
                                        webix.message({ type: "error", text: "Por favor, selecciona una fila primero" });
                                    }
                                }
                            },
                            {
                                view: "button",
                                type: "icon",
                                id: "btn_rechazar",
                                label: "Rechazar (Ctrl+R)",
                                icon: "mdi mdi-close-circle",
                                hotkey: "ctrl-r", 
                                width: 180,
                                click: function() {
                                    // 1. Obtenemos la tabla por su ID
                                    var tabla = $$("dtable");
                                    
                                    // 2. Obtenemos el ID de la fila seleccionada
                                    var idSeleccionado = tabla.getSelectedId();

                                    if (idSeleccionado) {
                                        // Aquí iría tu llamada al API para guardar en MariaDB si fuera necesario
                                        // ...
                                        
                                        Swal.fire({
                                        title: 'Rechazo de Documento',
                                        text: 'Ingrese el motivo o comentario del rechazo:',
                                        input: 'text',
                                        inputPlaceholder: 'Escriba el motivo aquí...',
                                        showCancelButton: true,
                                        confirmButtonText: 'Aceptar',
                                        cancelButtonText: 'Cancelar',
                                        inputValidator: (value) => {
                                            if (!value) {
                                                return '¡El motivo es obligatorio para continuar!';
                                            }
                                        }
                                        }).then((result) => {
                                            if (result.isConfirmed) {
                                                // El valor capturado está en result.value
                                                var motivo = result.value;

                                                webix.ajax().post("/api/progap/progap_focamx3", { id: idSeleccionado.id, nota: motivo })
                                                    .then(function(res) {
                                                        var data = res.json();
                                                        console.log(data)

                                                        // Verificamos si el backend regresó éxito (asumiendo que mandas {status: "success"})
                                                        if (data && data.status == "success") {
                                                            
                                                            // 1. Mensaje de éxito
                                                            webix.message({ type: "error", text: "Documento rechazado" });

                                                            // 2. Eliminamos la fila físicamente de la tabla
                                                            tabla.remove(idSeleccionado);

                                                            // 3. Seleccionamos el siguiente registro
                                                            var primerId = tabla.getFirstId();
                                                            if (primerId) {
                                                                tabla.select(primerId);
                                                            } else {
                                                                // Si ya no hay registros, limpiamos el visor de PDF
                                                                $$("visor_progap").setValues({ src: "" });
                                                            }

                                                        } else {
                                                            // Manejo de error lógico (ej. el registro ya estaba validado)
                                                            webix.alert({
                                                                title: "Atención",
                                                                type: "alert-error",
                                                                text: data.message || "Hubo un problema al validar el documento"
                                                            });
                                                        }
                                                    })
                                                    .catch(function(err) {
                                                        tabla.hideProgress();
                                                        // Manejo de error de red o servidor (Error 500, 404, etc.)
                                                        webix.message({ type: "error", text: "Error de conexión con el servidor" });
                                                        console.error("Error Ajax:", err);
                                                    });
                                            }
                                        });
                                        
                                    } else {
                                        webix.message({ type: "error", text: "Por favor, selecciona una fila primero" });
                                    }
                                }
                            },
                            <%}else{%>
                            {},
                            <%}%>
                            {
                                view: "combo", id: "cmbSoli", name: "cmbSoli", value: "<%=rows[0].id%>",
                                width: 120,
                                options: {
                                    fitMaster: false,
                                    width: 200,
                                    body: {
                                        data: [
                                    <%for (var i = 0; i < rows.length; i++) {%>
                                    { id: "<%= rows[i].id%>", value: "<%=rows[i].anio%>" },
                                    <%}%>

                                ]
                                    }
                                },
                                on: {
                                    onChange: genera

                                }
                            },

                        ]
                    },
                    {cols :[
                    {
                        view:"datatable", id:"dtable", select:true, footer:true, editable:true, hidden:false, minHeight:500, scroll:true,
                        resizeColumn: true,  navigation: true, resizeRow:true, css:"celda_compacta", tooltip:true,
                        rightSplit:1, leftSplit:3,
                        scheme: {
                            $init: function (obj) {
                                obj.fecha = (obj.fecha ? (obj.fecha == '01/01/1900'?'': convertDate(obj.fecha) ) : '');
                            }
                        },

                        columns:[
                        {
                            id: "detalle", width: 40,sort: "int", css: { 'text-align': 'center' }, 
                            header: [{text:"",css:"my_style"}, {text:""}],
                            template:(obj)=>{
                                return `
                                    <a href="#" onClick="deta_grup(${obj.id});">
                                        <i style='font-size:26px;color:#2b96cc;' class='fa-solid fa-magnifying-glass'></i>
                                    </a>`
                            }
                        },
                        {
                            id: "rank", width: 70,sort: "int", css: { 'text-align': 'center' }, 
                            header: [{text:"#",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },	
                        {
                            id: "folio", width: 80,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Oficio",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "fecha_solicitud", width: 120,sort: "string", css: { 'text-align': 'center' }, 
                            header: [{text:"Fecha solicitud",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },                        	
                        {
                            id: "dependencia", width: 80,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"C. U.",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },			
                        {
                            id: "codigo", width: 100,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Código",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },			
                        {
                            id: "nombre", width: 250,sort: "string", css: { 'text-align': 'left' }, 
                            fillspace:true, minWidth:150, header: [{text:"Nombre",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },			
                        {
                            id: "programa", width: 300, sort: "string", css: { 'text-align': 'left' }, 
                            fillspace:true, minWidth:150, header: [{text:"Programa posgrado",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "status", width: 180,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Estatus",css:"my_style"}, {
                                content: "selectFilter", placeholder:"Filtrar",
                            }],
                        },
                        ],
                        on: {
                            onAfterSelect: function(id, e, node) {
                                var item = this.getItem(id.row);
                                var visor = $$("visor_progap"); // ID del componente donde se verá la imagen/PDF
                                var header = $$("head_visor"); // Seleccionamos el contenedor del título
                                header.define("header", `<div class='header_multiline'>Tramite de: ${item.nombre} </br> ${item.programa}</div>`);
                                header.refresh(); // VITAL para que Webix repinte el texto

                                // Agregamos una máscara de carga (opcional pero recomendado)
                                webix.extend(visor, webix.ProgressBar);
                                
                                if(!$$("head_visor").config.collapsed){
                                    visor.showProgress();
                                    // Llamada a tu API pasando el ID del registro
                                    webix.ajax().get("/api/progap/progap_focamx2?id=" + item.id).then(function(res) {
                                        var respuesta = res.json();
                                        
                                        if (respuesta && respuesta.success) {
                                            // Si es una imagen en base64:
                                            visor.setValues({ src: respuesta.data });
                                            // Si usas el iframe que definimos antes, el template lo renderizará
                                        } else {
                                            webix.message({ type: "error", text: "No se pudo recuperar el archivo" });
                                        }
                                        visor.hideProgress();
                                    }).catch(function(err) {
                                        webix.message({ type: "error", text: "Error de conexión con el servidor" });
                                        visor.hideProgress();
                                    });
                                }
                                else
                                {
                                    $$("visor_progap").setValues({ src: "" });
                                }
                            }
                        },
                    },
                    { view:"resizer" }, // Opcional: para ajustar el ancho manualmente
                    {
                        id:"head_visor",
                        header: "<div class='header_multiline'>Da clic en el trámite para ver el documento</div>",
                        body:{
                            view: "template",
                            id: "visor_progap",
                            width: 630,
                            template: function(obj) {
                                if (!obj.src) return "<div style='padding:20px;text-align:center;'>Esperando archivo...</div>";
                                
                                // Si lo que recibes es un PDF:
                                return `<iframe src="${obj.src}" width="100%" height="100%" style="border:none;"></iframe>`;
                                
                                // SI ES UNA IMAGEN, cambia el retorno a:
                                // return `<img src="${obj.src}" style="width:100%; height:auto;">`;
                            }
                        },
                    },
                    ]},
                ]
            });

						webix.ui({
	            view:"contextmenu", id:"cmenu", master:$$("dtable"), width:220,
	            data:[
	              {value:"Eliminar grupo", id:"eliminaGrupo"},
	              
	            ],
	            on:{
	              "onItemClick":function(id){
	                var id_grup = $$("dtable").getSelectedId();
	                if(id === "eliminaGrupo"){
	                	console.log(id_grup)
	                  eliminaGrupo(id_grup.id)
	                }
	                
	              }
	            }
	          });

            genera();
        });

        function genera() {
            $$("dtable").clearAll();
            $$("dtable").load("/api/progap/progap_focamx?lnConv=" + $$("cmbSoli").getValue() + "&llTodo=" + <%-(llRevisor?`$$("chk_todos").getValue()`:'0')%>)

        }

        function deta_grup(id) {
            window.parent.$$("tbView").addView({
                header: "<span class='webix_icon mdi mdi-file-document-outline'></span>" + (id == undefined ? "Nuevo" : "Modifica") + " FOCAM",
                body: {
                    view: "iframe", src: "/progap/progap_nfocam?lnID=" + id,
                    type: {
                        height: 60
                    }
                },
                close: true
            });
            window.parent.$$("tbView").getTabbar().setValue(window.parent.$$("tbView").getTabbar().data.options[window.parent.$$("tbView").getTabbar().data.options.length - 1].id);
        }

        function eliminaGrupo(id) {

          Swal.fire({
					  title: "", text: 'Seguro de eliminar el grupo?', icon: 'warning', showCancelButton: true,
					  confirmButtonColor: '#3085d6', cancelButtonColor: '#d33', confirmButtonText: 'Si', cancelButtonText:"No",
					}).then((result) => {
						if(result.isConfirmed){
							webix.ajax().post("/<% // Response.write(config.ruta)%>/op_ngrupx.fwx?t=1", {id:id}).then((res)=>{
								res = res.json();
								Swal.fire('', res.message, res.status?"success":"error").then(()=>{
									if(res.status){
										genera()
									}
								})
							})
						}
					})
        }



        function agregar() {

            var checked = [];
            $$("dtable").data.each(function (obj) {
                if (obj.marcar == 1) checked.push(obj.id);
            });
            
            $$("dtable").remove(checked);
            window.parent.parent.carg_grupo(checked.toString());
        }

    </script>
</body>


</html>