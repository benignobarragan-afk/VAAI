<%- include('../partials/header'); %>

<body onLoad="doOnLoad();">
    <div align="center" id="cuerpo">
            <div id="view_ui"></div>
    </div>
    <script>
        var tip = 0
        var w1;
        var mygrid;

        //alert(tip);

        function doOnLoad() {


            webix.ui.datafilter.rowCount = webix.extend({
                refresh: function (master, node, value) {
                    node.firstChild.innerHTML = "Total: " + master.count();
                }
            }, webix.ui.datafilter.summColumn)


            var ui = webix.ui({
                space: "wide",
                rows: [
                    {
                    cols:[
                        {    
                            view:"form", id:"formPDF", name:"formPDF", rows: [
                                { 
                                view: "uploader", value: "Selecciona un archivo de Excel", 
                                accept: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel",
                                name:"filePDF", id:"filePDF", 
                                link:"list1",  upload:"/api/progap/progap_actu_estux",
                                    on:{
                                        onUploadComplete: function(response, file) {
                                            var form = $$("formPDF");
                                            form.enable();
                                            form.hideProgress(); // Apagamos la barra de progreso
                                            
                                            // 1. Manejo de error grave desde el backend (ej. archivo corrupto, error SQL en MariaDB)
                                            if (response.status === "error") {
                                                webix.alert({
                                                    title: "Error del Servidor",
                                                    type: "alert-error",
                                                    text: response.message || "No se pudo procesar el archivo."
                                                });
                                                return false; // Detenemos la ejecución aquí
                                            }

                                            // 2. Manejo de errores lógicos (los datos se leyeron, pero hay Centros Universitarios no válidos)
                                            if (response.erro_arch) {
                                                $$("cmdAplica").disable();
                                                webix.alert({
                                                    title: "Revisión necesaria",
                                                    type: "alert-warning",
                                                    text: "Hay algunos errores de los catálogos en el archivo. Revísalo y corrígelo para poder aplicar."
                                                });
                                            } else {
                                                $$("cmdAplica").enable();
                                                webix.message({ type: "success", text: "Archivo validado correctamente. Listo para aplicar." });
                                            }

                                            // 3. Limpiamos y cargamos la tabla SOLO si recibimos el arreglo de actualización
                                            $$("dtable").clearAll();
                                            if (response.laActualiza && response.laActualiza.length > 0) {
                                                $$("dtable").parse(response.laActualiza);
                                            }
                                        },
                                        onBeforeFileAdd: function (item) {
                                            var form = $$("formPDF");
                                            form.disable(); 
                                            
                                            // Activamos la barra de progreso para que el usuario sepa que Node.js está trabajando
                                            webix.extend(form, webix.ProgressBar);
                                            form.showProgress();
                                            
                                            webix.message({ type: "info", text: "Subiendo y procesando archivo de Excel..." });
                                            return true;
                                        },
                                        onUploadFail: function (item) {
                                            var form = $$("formPDF");
                                            form.enable(); 
                                            form.hideProgress();
                                            
                                            // Esto salta si el puerto 3000 se cae o hay un error 500/404 de red
                                            webix.alert({
                                                title: "Error de Conexión",
                                                type: "alert-error",
                                                text: "No se pudo establecer comunicación con el servidor. Intenta de nuevo."
                                            });
                                        }

                                    }
                                },
                                {
                                view:"list",  id:"list1", type:"uploader",
                                autoheight:true, borderless:true	
                                },
                            ]
                        },
                        {
                            view: "button",
                            id:"cmdAplica",
                            type: "icon",
                            icon: "mdi mdi-database-import",
                            label: "Aplicar cambios",
                            width: 230,
                            on: {
                                onItemClick: function () { 
                                    guardar();
                                }
                            }
                        },
                        {
                            view: "button",
                            type: "icon",
                            icon: "mdi mdi-file-excel",
                            label: "Descargar",
                            width: 130,
                            on: {
                                onItemClick: function () { 
                                    webix.toExcel("dtable", {
                                        //spans:true,
                                        //styles:true
                                    });
                                    }
                            }
                        },
                    ]},
                    {
                        view:"datatable", id:"dtable", select:true, minHeight:500, scroll:true, footer:true,
                        resizeColumn: true,  navigation: true, resizeRow:true, tooltip:true, 
                        rightSplit:2, leftSplit:1,
                        scheme: {
                            $init: function (obj) {
                                obj.fecha = (obj.fecha ? (obj.fecha == '01/01/1900'?'': convertDate(obj.fecha) ) : '');
                            }
                        },

                        columns:[	
                        { id: "marcar", 
