                            }],
                        },
                        {
                            id: "avance", width: 100,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Avance",css:"my_style"}, {
                                content: "selectFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "clave_911", width: 100,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Clave 911",css:"my_style"}, {
                                content: "selectFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "clave_CGIPV", width: 140,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Clave única",css:"my_style"}, {
                                content: "textFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "actual", width: 300,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Valor actual",css:"my_style"}, {
                                content: "excelFilter", placeholder:"Filtrar",
                            }],
                        },
                        {
                            id: "update", width: 300,sort: "string", css: { 'text-align': 'left' }, 
                            header: [{text:"Cambios",css:"my_style"}, {
                                content: "excelFilter", placeholder:"Filtrar",
                            }],
                        },
                        ], 
                    },
                ]
            });

    }

    function guardar() {
        // Webix filtra la tabla y nos devuelve solo los objetos marcados
        var checked = $$("dtable").find(function(obj) {
            return obj.marcar == 1;
        });

        // Pequeña validación por si le dan a guardar sin marcar nada
        if (checked.length === 0) {
            webix.message({ type: "warning", text: "Por favor, marca al menos un registro." });
            return;
        }

        Swal.fire({
            title: '¿Seguro de aplicar el(los) ' + checked.length + ' cambio(s)?', 
            icon: 'warning', 
            showCancelButton: true,
            confirmButtonColor: '#3085d6', 
            cancelButtonColor: '#d33', 
            confirmButtonText: 'Aceptar'
        }).then((result) => {
            if (result.isConfirmed) {
                webix.ajax().headers({"Content-Type": "application/json"})
                    .post("/api/progap/progap_actu_estux2", JSON.stringify(checked))
                    .then(function (res) {
                        var response = res.json();
                        webix.message({ 
                            type: (response.error ? "error" : "success"), 
                            text: response.mensage, 
                            expire: 2500 
                        });
                        
                        if (!response.error) {
                            $$("dtable").clearAll();
                        }
                    }).fail(function(err){
                        webix.message({ type: "error", text: "Error de comunicación con el servidor." });
                    });
            }
        });
    }
    
    </script>
</body>


