                        onClick: {
                            // Esta función se activa al hacer clic en cualquier elemento con la clase 'btn_ver_grupo'
                            "btn_ver_detalle": function(ev, id) {
                                // Obtenemos el objeto de la fila seleccionada
                                const obj = this.getItem(id); 
                                deta_grup(obj.id);
